# Fastlane per l'app iOS "Cerca posta".
#
# Firma + upload su TestFlight dalla CI (runner macOS di GitHub Actions), senza Mac locale.
# Autenticazione con App Store Connect API key (.p8 dai secret ASC_*). La FIRMA usa fastlane
# match: UN solo certificato di distribuzione + profilo App Store, salvati cifrati in uno storage
# git privato (secret MATCH_*) e RIUSATI a ogni build. Così la CI non crea piu' un certificato
# nuovo a ogni run — era quello a riempire la quota Apple («maximum number of certificates»),
# che faceva fallire l'archive con «No profiles for 'it.cercaposta.app' were found».
#
# BOOTSTRAP (una tantum): `bundle exec fastlane certificates` (workflow ios-signing-bootstrap) —
#   crea il certificato + profilo e li salva in match. Richiede uno slot certificato LIBERO
#   nell'account Apple (revoca prima i vecchi certificati di distribuzione).
# RELEASE: `bundle exec fastlane beta` (workflow mobile → job release-ios) — match in read-only.
# Env: ASC_KEY_ID, ASC_ISSUER_ID, APPLE_TEAM_ID, MATCH_PASSWORD, MATCH_GIT_URL,
#      MATCH_GIT_BASIC_AUTHORIZATION.

default_platform(:ios)

APP_ID = "it.cercaposta.app"

platform :ios do
  desc "Bootstrap firma (una tantum): crea certificato App Store + profilo e li salva in match"
  lane :certificates do
    key_id = ENV.fetch("ASC_KEY_ID")
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8"),
    )
    match(
      type: "appstore",
      app_identifier: APP_ID,
      api_key: api_key,
      readonly: false,
    )
  end

  desc "Compila (firma via match read-only) e carica su TestFlight"
  lane :beta do
    # Su CI: keychain temporaneo dedicato per match (evita i popup/ACL su login.keychain, che
    # su runner headless bloccano il code signing con «SecKeychainItemSetAccessWithPassword»).
    setup_ci

    key_id = ENV.fetch("ASC_KEY_ID")
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8"),
    )

    # Scarica (read-only) il certificato + profilo App Store dallo storage e li installa nel
    # keychain: nessuna creazione → la quota certificati Apple non viene mai toccata.
    match(
      type: "appstore",
      app_identifier: APP_ID,
      api_key: api_key,
      readonly: true,
    )

    # match espone il nome esatto del profilo installato in questa env var; fallback al nome
    # canonico «match AppStore <bundle>».
    profile = ENV["sigh_#{APP_ID}_appstore_profile-name"] || "match AppStore #{APP_ID}"

    # Firma manuale SOLO sul target dell'app (Runner). Passare i signing settings globalmente via
    # xcargs li applicava anche ai target dei Pods, che NON supportano i provisioning profile
    # («... does not support provisioning profiles»). Toccando solo Runner.xcodeproj, i Pods
    # restano in firma automatica senza profilo e l'archive va a buon fine.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      profile_name: profile,
      targets: ["Runner"],
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        teamID: ENV.fetch("APPLE_TEAM_ID"),
        provisioningProfiles: { APP_ID => profile },
      },
      # Firma MANUALE col profilo di match anche per l'ARCHIVE (non solo l'export): niente
      # -allowProvisioningUpdates (che creerebbe certificati). Il team + il profilo vengono
      # dai secret / da match.
      output_directory: "build",
      output_name: "Runner.ipa",
      clean: true,
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )
  end
end
