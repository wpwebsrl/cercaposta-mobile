<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Cerca posta</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>cercaposta</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>CFBundleLocalizations</key>
		<array>
			<string>en</string>
			<string>it</string>
		</array>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<!-- Valori base (dev region = en). Le traduzioni per lingua sono in
	     Runner/{en,it}.lproj/InfoPlist.strings, ORA registrate come Variant Group
	     nel target Xcode (project.pbxproj): iOS mostra il testo tradotto e ripiega
	     su questi valori base. -->
		<key>NSMicrophoneUsageDescription</key>
		<string>The microphone is used for voice search in your email archive.</string>
		<key>NSSpeechRecognitionUsageDescription</key>
		<string>Speech recognition converts your voice into text for search. Processing happens on-device.</string>
		<key>NSFaceIDUsageDescription</key>
		<string>Face ID unlocks access to your encrypted archive.</string>
		<!-- Il server può essere su rete locale (IP LAN del PC, es. test da TestFlight):
	     iOS 14+ richiede questa descrizione o la connessione al LAN fallisce in silenzio. -->
		<key>NSLocalNetworkUsageDescription</key>
		<string>Connects to your CercaPosta server, which may be on your local network.</string>
		<!-- Richieste da flutter_quill (plugin nativo quill_native_bridge, che referenzia
	     le API Photos: `import Photos` + PHPhotoLibrary in saveImageToGallery). L'app NON
	     usa queste funzioni (editor solo testo), ma Apple pretende comunque la purpose
	     string per i simboli linkati (ITMS-90683), altrimenti rifiuta l'upload. -->
		<key>NSPhotoLibraryUsageDescription</key>
		<string>Allows the message editor to add images from your photo library.</string>
		<key>NSPhotoLibraryAddUsageDescription</key>
		<string>Allows the message editor to save images to your photo library.</string>
		<!-- L'app usa solo crittografia standard (HTTPS/TLS, Keychain, biometria):
	     rientra nell'esenzione, quindi niente prompt di export-compliance a ogni
	     upload TestFlight. Se un domani si aggiunge crittografia non-standard,
	     rivalutare (potrebbe servire documentazione all'esportazione). -->
		<key>ITSAppUsesNonExemptEncryption</key>
		<false/>
		<key>UIStatusBarHidden</key>
		<false/>
		<!-- Notifiche di sistema (docs/notifiche.md): il poll in background che le mostra gira via
		     workmanager → BGAppRefreshTask. iOS lo esegue in modo OPPORTUNISTICO (non garantito).
		     UIBackgroundModes abilita il fetch; l'identificatore va dichiarato qui. -->
		<key>UIBackgroundModes</key>
		<array>
			<string>fetch</string>
			<string>processing</string>
		</array>
		<key>BGTaskSchedulerPermittedIdentifiers</key>
		<array>
			<string>it.cercaposta.app.notifyfetch</string>
			<string>be.tramckrijte.workmanager.BackgroundRefreshTask</string>
			<string>be.tramckrijte.workmanager.BackgroundTask</string>
		</array>
	</dict>
</plist>
